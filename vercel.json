{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --filter @workspace/pawan-security...",
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/pawan-security run build",
  "outputDirectory": "artifacts/pawan-security/dist/public",
  "rewrites": [
    {
      "source": "/((?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
 